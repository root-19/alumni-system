# Railway Environment Configuration
DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/database.sqlite

# Laravel Settings
APP_ENV=production
APP_DEBUG=false
LOG_CHANNEL=stderr

# Cache & Session
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# Filesystem
FILESYSTEM_DISK=local

# SimpleCert API
SIMPLECERT_EMAIL=your-email@example.com
SIMPLECERT_PASSWORD=your-password
SIMPLECERT_API_KEY=your-api-key
